# =========================
# Python cache / bytecode
# =========================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# =========================
# Build / packaging
# =========================
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# =========================
# Virtual environments
# =========================
.env
.venv/
venv/
env/
ENV/
.python-version

# =========================
# IDE / OS junk
# =========================
.idea/
.vscode/
.spyderproject
.spyproject
.ropeproject
.DS_Store
Thumbs.db

# =========================
# Test / coverage cache
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.hypothesis/

# =========================
# Runtime logs / tensorboard
# =========================
*.log
nohup.out
tensorboard/
tensorboard*/

# =========================
# Large generated artifacts (baseline-style)
# =========================
data/
result/

# Keep runnable scripts and docs under result when needed
!result/
!result/**/*.py
!result/**/*.md
!result/**/*.txt

# =========================
# Model checkpoints (generated)
# Keep source model definitions (fl_model.py)
# =========================
models/**/global*
models/**/gateway*
models/**/*.pt
models/**/*.pth
models/**/*.ckpt
models/**/*.pkl
models/**/*.npy
models/**/*.npz

# =========================
# Common generated files
# =========================
*.csv
*.png
*.jpg
*.jpeg
*.pdf
*.svg
*.parquet
*.jsonl
*.npy
*.npz
*.pkl
**/events.out.tfevents.*
